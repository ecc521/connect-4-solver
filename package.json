{
  "name": "connect-4-solver",
  "version": "4.0.0",
  "description": "High-performance solver for a variety of board sizes using NNUE + alpha-beta pruning. Bindings for WASM, Node.js, and React Native.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./threaded": {
      "types": "./dist/threaded.d.ts",
      "default": "./dist/threaded.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "default": "./dist/native.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./async": {
      "types": "./dist/async.d.ts",
      "default": "./dist/async.js"
    },
    "./worker-handler": {
      "types": "./dist/worker-handler.d.ts",
      "default": "./dist/worker-handler.js"
    }
  },
  "files": [
    "dist",
    "data",
    "build/analyze.js",
    "build/analyze_threaded.js",
    "android",
    "ios",
    "native",
    "connect-4-solver.podspec"
  ],
  "scripts": {
    "install": "node-gyp rebuild || echo 'Native Addon compilation skipped/failed. Falling back to WASM bundle.'",
    "build": "npm run build:wasm && npm run build:ts",
    "build:wasm": "bash build.sh",
    "build:ts": "tsc",
    "test": "npm run lint && npm run format:check && jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run lint && npm run build:ts && npm run format:check && npm test",
    "example:ios": "cd example && npx react-native run-ios --simulator=\"iPhone 15\"",
    "example:android": "cd example && npx react-native run-android",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecc521/connect4.git"
  },
  "author": "Tucker Willenborg",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/ecc521/connect4/issues"
  },
  "homepage": "https://github.com/ecc521/connect4#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitepress": "^1.6.4"
  },
  "types": "dist/index.d.ts",
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.7.0"
  }
}
