{
  "name": "connect-4-solver",
  "version": "4.1.0",
  "description": "High-performance solver for a variety of board sizes using NNUE + alpha-beta pruning. Bindings for WASM, Node.js, and React Native.",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./threaded": {
      "types": "./dist/threaded.d.ts",
      "default": "./dist/threaded.js"
    },
    "./sync": {
      "types": "./dist/sync.d.ts",
      "default": "./dist/sync.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "default": "./dist/native.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./async": {
      "types": "./dist/async.d.ts",
      "default": "./dist/async.js"
    },
    "./worker-handler": {
      "types": "./dist/worker-handler.d.ts",
      "default": "./dist/worker-handler.js"
    }
  },
  "files": [
    "dist",
    "build/analyze.js",
    "build/analyze_threaded.js",
    "build/analyze.wasm",
    "build/analyze_threaded.wasm",
    "build/analyze_threaded.worker.js",
    "android/src",
    "android/cpp",
    "android/CMakeLists.txt",
    "android/build.gradle",
    "ios",
    "native",
    "connect-4-solver.podspec",
    "binding.gyp"
  ],
  "scripts": {
    "install": "node-gyp rebuild --jobs max || echo 'Native Addon compilation skipped/failed. Falling back to WASM bundle.'",
    "build": "npm run build:wasm && npm run build:ts",
    "build:ts": "tsc -p tsconfig.build.json",
    "build:wasm": "bash build.sh",
    "build:native": "npx node-gyp rebuild --jobs max",
    "build:native:pgo": "bash build_native_pgo.sh && npx node-gyp rebuild --use_pgo=true --jobs max",
    "test": "npm run lint && NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bench": "node --loader ts-node/esm tools/bench.ts --native",
    "bench:node": "node --loader ts-node/esm tools/bench.ts --native",
    "bench:wasm": "node --loader ts-node/esm tools/bench.ts --wasm",
    "bench:cpp": "bash tools/benchmarks/run_native_bench.sh",
    "bench:book": "node --loader ts-node/esm tools/bench.ts --native --book",
    "bench:pgo:native": "npx node-gyp rebuild --jobs max && node --loader ts-node/esm tools/bench.ts --native --json > /tmp/c4_baseline.json && echo '--- Baseline captured ---' && npm run build:native:pgo && node --loader ts-node/esm tools/bench.ts --native --json > /tmp/c4_pgo.json && echo '--- PGO captured ---' && node --loader ts-node/esm tools/compare-bench.ts /tmp/c4_baseline.json /tmp/c4_pgo.json",
    "docker:build:image": "docker build -t connect-4-wasm-builder .",
    "docker:build:wasm": "docker run --rm -v $(pwd):/workspace connect-4-wasm-builder bash build.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "build:release": "npm run docker:build:wasm && npm run build:ts",
    "prepublishOnly": "npm run lint && npm run format:check && npm run build:release && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecc521/connect4.git"
  },
  "author": "Tucker Willenborg",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/ecc521/connect4/issues"
  },
  "homepage": "https://github.com/ecc521/connect4#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.5.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitepress": "^1.6.4"
  },
  "types": "dist/index.d.ts",
  "dependencies": {
    "bindings": "^1.5.0",
    "node-addon-api": "^8.7.0"
  }
}
